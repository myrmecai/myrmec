<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Secrets storage (two-tier: GLOBAL when project_id IS NULL, otherwise PROJECT-scoped).

        - `type`        : credential shape (BEARER_TOKEN, USERNAME_PASSWORD, API_KEY, ...).
                          Drives the SecretPayload subtype the API accepts/returns.
        - `backend`     : where the value lives (LOCAL = in this DB column, others reserved for
                          Vault / cloud secret managers).
        - `backend_ref` : opaque pointer used by non-LOCAL backends.
        - `encrypted_value` : AES-256-GCM ciphertext, only for backend = LOCAL.
    -->

    <changeSet id="20260405-03-01" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not><tableExists tableName="secrets"/></not>
        </preConditions>
        <createTable tableName="secrets">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="project_id" type="uuid"/>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="type" type="varchar(40)">
                <constraints nullable="false"/>
            </column>
            <column name="backend" type="varchar(40)" defaultValue="LOCAL">
                <constraints nullable="false"/>
            </column>
            <column name="backend_ref" type="text"/>
            <column name="encrypted_value" type="bytea"/>
            <column name="config" type="text"/>
            <column name="created_by" type="uuid"/>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Foreign key to projects (nullable: NULL = global secret) -->
    <changeSet id="20260405-03-02" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not><foreignKeyConstraintExists foreignKeyName="fk_secrets_project"/></not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="secrets"
            baseColumnNames="project_id"
            referencedTableName="projects"
            referencedColumnNames="id"
            constraintName="fk_secrets_project"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- Foreign key to users (created_by) -->
    <changeSet id="20260405-03-03" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not><foreignKeyConstraintExists foreignKeyName="fk_secrets_created_by"/></not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="secrets"
            baseColumnNames="created_by"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_secrets_created_by"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- Index for looking up project-scoped secrets -->
    <changeSet id="20260405-03-04" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not><indexExists indexName="idx_secrets_project_id"/></not>
        </preConditions>
        <createIndex tableName="secrets" indexName="idx_secrets_project_id">
            <column name="project_id"/>
        </createIndex>
    </changeSet>

    <!-- Partial unique indexes: name unique per scope (global, or per-project).
         PostgreSQL only — H2 / e2e profile relies on application-level enforcement. -->
    <changeSet id="20260405-03-05" author="myrmec" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <not><indexExists indexName="uq_secrets_global_name"/></not>
        </preConditions>
        <sql>
            CREATE UNIQUE INDEX uq_secrets_global_name ON secrets (name) WHERE project_id IS NULL;
        </sql>
    </changeSet>

    <changeSet id="20260405-03-06" author="myrmec" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <not><indexExists indexName="uq_secrets_project_name"/></not>
        </preConditions>
        <sql>
            CREATE UNIQUE INDEX uq_secrets_project_name ON secrets (project_id, name) WHERE project_id IS NOT NULL;
        </sql>
    </changeSet>

    <!-- Backend-aware CHECK: LOCAL must have ciphertext; non-LOCAL must have backend_ref -->
    <changeSet id="20260405-03-07" author="myrmec" dbms="postgresql">
        <preConditions onFail="MARK_RAN">
            <sqlCheck expectedResult="0">
                SELECT COUNT(*) FROM pg_constraint WHERE conname = 'ck_secrets_backend_payload'
            </sqlCheck>
        </preConditions>
        <sql>
            ALTER TABLE secrets ADD CONSTRAINT ck_secrets_backend_payload CHECK (
                (backend = 'LOCAL' AND encrypted_value IS NOT NULL)
                OR (backend &lt;&gt; 'LOCAL' AND backend_ref IS NOT NULL)
            );
        </sql>
    </changeSet>

</databaseChangeLog>
