<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260530-02-projects-group-id" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="projects" columnName="group_id"/>
            </not>
        </preConditions>
        <comment>Every project belongs to exactly one group. Backfill existing rows to the seeded
            Default group, then enforce NOT NULL + FK.</comment>

        <addColumn tableName="projects">
            <column name="group_id" type="uuid"/>
        </addColumn>

        <update tableName="projects">
            <column name="group_id" value="00000000-0000-0000-0000-000000000001"/>
            <where>group_id IS NULL</where>
        </update>

        <addNotNullConstraint tableName="projects" columnName="group_id" columnDataType="uuid"/>

        <addForeignKeyConstraint
            baseTableName="projects"
            baseColumnNames="group_id"
            constraintName="fk_projects_group"
            referencedTableName="groups"
            referencedColumnNames="id"
            onDelete="RESTRICT"/>

        <createIndex indexName="idx_projects_group_id" tableName="projects">
            <column name="group_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
