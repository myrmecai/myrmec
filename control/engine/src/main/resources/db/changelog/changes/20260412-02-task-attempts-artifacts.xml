<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- ====================================================================== -->
    <!-- TASK ATTEMPTS TABLE - Individual execution attempts for a task         -->
    <!-- ====================================================================== -->
    <changeSet id="20260412-02-01-task-attempts" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="task_attempts"/>
            </not>
        </preConditions>

        <createTable tableName="task_attempts">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="task_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="attempt_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>

            <column name="agent_instance_id" type="UUID">
                <constraints nullable="true"/>
            </column>

            <!-- RUNNING, COMPLETED, FAILED, ABANDONED, SKIPPED -->
            <column name="status" type="VARCHAR(20)" defaultValue="RUNNING">
                <constraints nullable="false"/>
            </column>

            <!-- SUCCESS, FAILURE (null while running) -->
            <column name="result" type="VARCHAR(20)"/>

            <column name="output" type="TEXT"/>

            <column name="error_message" type="TEXT"/>

            <!-- Structured error code for programmatic handling -->
            <column name="error_code" type="VARCHAR(50)"/>

            <column name="started_at" type="TIMESTAMP WITH TIME ZONE" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="completed_at" type="TIMESTAMP WITH TIME ZONE"/>
        </createTable>

        <rollback>
            <dropTable tableName="task_attempts"/>
        </rollback>
    </changeSet>

    <!-- Unique constraint: one attempt number per task -->
    <changeSet id="20260412-02-02-task-attempts-unique" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="uk_task_attempts_task_attempt"/>
            </not>
        </preConditions>
        <addUniqueConstraint
            tableName="task_attempts"
            columnNames="task_id, attempt_number"
            constraintName="uk_task_attempts_task_attempt"/>
    </changeSet>

    <!-- FK to workflow_tasks -->
    <changeSet id="20260412-02-03-task-attempts-fk-task" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_task_attempts_task"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="task_attempts"
            baseColumnNames="task_id"
            referencedTableName="workflow_tasks"
            referencedColumnNames="id"
            constraintName="fk_task_attempts_task"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- FK to agent_instances -->
    <changeSet id="20260412-02-04-task-attempts-fk-agent" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_task_attempts_agent_instance"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="task_attempts"
            baseColumnNames="agent_instance_id"
            referencedTableName="agent_instances"
            referencedColumnNames="id"
            constraintName="fk_task_attempts_agent_instance"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- Index for querying attempts by task -->
    <changeSet id="20260412-02-05-task-attempts-idx" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_task_attempts_task_id"/>
            </not>
        </preConditions>
        <createIndex tableName="task_attempts" indexName="idx_task_attempts_task_id">
            <column name="task_id"/>
            <column name="attempt_number"/>
        </createIndex>
    </changeSet>

    <!-- ====================================================================== -->
    <!-- ARTIFACTS REPO - Add to workflows table                                -->
    <!-- ====================================================================== -->
    <changeSet id="20260412-02-06-workflows-artifacts-repo" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="workflows" columnName="artifacts_repo"/>
            </not>
        </preConditions>
        <addColumn tableName="workflows">
            <column name="artifacts_repo" type="TEXT">
                <constraints nullable="true"/>
            </column>
        </addColumn>
        <comment>JSON: {url, baseBranch, credentialSecretId}</comment>
    </changeSet>

    <!-- ====================================================================== -->
    <!-- WORKFLOW_TASKS - Add current_attempt_id                                -->
    <!-- ====================================================================== -->
    <changeSet id="20260412-02-07-tasks-current-attempt" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="workflow_tasks" columnName="current_attempt_id"/>
            </not>
        </preConditions>
        <addColumn tableName="workflow_tasks">
            <column name="current_attempt_id" type="UUID">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- FK for current_attempt_id (added separately to avoid circular dep during creation) -->
    <changeSet id="20260412-02-08-tasks-current-attempt-fk" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_workflow_tasks_current_attempt"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="workflow_tasks"
            baseColumnNames="current_attempt_id"
            referencedTableName="task_attempts"
            referencedColumnNames="id"
            constraintName="fk_workflow_tasks_current_attempt"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- ====================================================================== -->
    <!-- EXECUTION_EVENTS - Add attempt_id (keeping task_id for now)            -->
    <!-- ====================================================================== -->
    <changeSet id="20260412-02-09-events-attempt-id" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="execution_events" columnName="attempt_id"/>
            </not>
        </preConditions>
        <addColumn tableName="execution_events">
            <column name="attempt_id" type="UUID">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <!-- FK for attempt_id -->
    <changeSet id="20260412-02-10-events-attempt-fk" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_execution_events_attempt"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="execution_events"
            baseColumnNames="attempt_id"
            referencedTableName="task_attempts"
            referencedColumnNames="id"
            constraintName="fk_execution_events_attempt"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- Index for querying events by attempt -->
    <changeSet id="20260412-02-11-events-attempt-idx" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_execution_events_attempt_id"/>
            </not>
        </preConditions>
        <createIndex tableName="execution_events" indexName="idx_execution_events_attempt_id">
            <column name="attempt_id"/>
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
