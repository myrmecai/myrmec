<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- Workflow requests table - execution instances of workflows -->
    <changeSet id="20260405-05-01" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="workflow_requests"/>
            </not>
        </preConditions>
        <createTable tableName="workflow_requests">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="workflow_id" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="workflow_version" type="integer">
                <constraints nullable="false"/>
            </column>
            <column name="input" type="text"/>
            <column name="output" type="text"/>
            <column name="status" type="varchar(20)" defaultValue="PENDING">
                <constraints nullable="false"/>
            </column>
            <column name="error_message" type="text"/>
            <column name="created_by" type="uuid">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp with time zone" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="started_at" type="timestamp with time zone"/>
            <column name="completed_at" type="timestamp with time zone"/>
        </createTable>
    </changeSet>

    <!-- Foreign key to workflows -->
    <changeSet id="20260405-05-02" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_workflow_requests_workflow"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="workflow_requests"
            baseColumnNames="workflow_id"
            referencedTableName="workflows"
            referencedColumnNames="id"
            constraintName="fk_workflow_requests_workflow"
            onDelete="CASCADE"/>
    </changeSet>

    <!-- Foreign key to users (created_by) -->
    <changeSet id="20260405-05-03" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_workflow_requests_user"/>
            </not>
        </preConditions>
        <addForeignKeyConstraint
            baseTableName="workflow_requests"
            baseColumnNames="created_by"
            referencedTableName="users"
            referencedColumnNames="id"
            constraintName="fk_workflow_requests_user"
            onDelete="SET NULL"/>
    </changeSet>

    <!-- Index for looking up requests by workflow -->
    <changeSet id="20260405-05-04" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_workflow_requests_workflow_id"/>
            </not>
        </preConditions>
        <createIndex tableName="workflow_requests" indexName="idx_workflow_requests_workflow_id">
            <column name="workflow_id"/>
        </createIndex>
    </changeSet>

    <!-- Index for filtering by status -->
    <changeSet id="20260405-05-05" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_workflow_requests_status"/>
            </not>
        </preConditions>
        <createIndex tableName="workflow_requests" indexName="idx_workflow_requests_status">
            <column name="status"/>
        </createIndex>
    </changeSet>

    <!-- Index for filtering by created_at (recent requests) -->
    <changeSet id="20260405-05-06" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <indexExists indexName="idx_workflow_requests_created_at"/>
            </not>
        </preConditions>
        <createIndex tableName="workflow_requests" indexName="idx_workflow_requests_created_at">
            <column name="created_at" descending="true"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
