<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260412-01-add-source-to-execution-events" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="execution_events" columnName="source"/>
            </not>
        </preConditions>
        <comment>Add source column to execution_events for distinguishing TASK/AGENT/SYSTEM logs</comment>

        <addColumn tableName="execution_events">
            <column name="source" type="varchar(20)" defaultValue="TASK">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>

</databaseChangeLog>
