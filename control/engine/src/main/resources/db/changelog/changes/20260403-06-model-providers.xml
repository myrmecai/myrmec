    <changeSet id="20260403-06-add-provider-fk" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_models_provider"/>
            </not>
        </preConditions>
        <comment>Add foreign key from models to model_providers</comment>

        <addForeignKeyConstraint
            baseTableName="models"
            baseColumnNames="provider"
            referencedTableName="model_providers"
            referencedColumnNames="code"
            constraintName="fk_models_provider"
            onDelete="RESTRICT"
            onUpdate="CASCADE"/>
    </changeSet>

</databaseChangeLog>
