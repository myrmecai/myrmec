<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="20260403-01-create-authentication-providers" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="authentication_providers"/>
            </not>
        </preConditions>

        <createTable tableName="authentication_providers">
            <column name="code" type="varchar(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="provider_type" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="is_enabled" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="is_system" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="metadata" type="text" defaultValue="{}">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <insert tableName="authentication_providers">
            <column name="code" value="LOCAL"/>
            <column name="provider_type" value="LOCAL"/>
            <column name="name" value="Local Account"/>
            <column name="is_enabled" valueBoolean="true"/>
            <column name="is_system" valueBoolean="true"/>
            <column name="metadata" value="{}"/>
        </insert>

        <insert tableName="authentication_providers">
            <column name="code" value="OIDC_DEFAULT"/>
            <column name="provider_type" value="OIDC"/>
            <column name="name" value="OIDC (Default)"/>
            <column name="is_enabled" valueBoolean="false"/>
            <column name="is_system" valueBoolean="true"/>
            <column name="metadata" value="{}"/>
        </insert>

        <insert tableName="authentication_providers">
            <column name="code" value="GITHUB_DEFAULT"/>
            <column name="provider_type" value="GITHUB"/>
            <column name="name" value="GitHub (Default)"/>
            <column name="is_enabled" valueBoolean="false"/>
            <column name="is_system" valueBoolean="true"/>
            <column name="metadata" value="{}"/>
        </insert>

        <insert tableName="authentication_providers">
            <column name="code" value="GOOGLE_DEFAULT"/>
            <column name="provider_type" value="GOOGLE"/>
            <column name="name" value="Google (Default)"/>
            <column name="is_enabled" valueBoolean="false"/>
            <column name="is_system" valueBoolean="true"/>
            <column name="metadata" value="{}"/>
        </insert>

        <createIndex indexName="idx_authentication_providers_type" tableName="authentication_providers">
            <column name="provider_type"/>
        </createIndex>

        <createIndex indexName="idx_authentication_providers_enabled" tableName="authentication_providers">
            <column name="is_enabled"/>
        </createIndex>

    </changeSet>

    <changeSet id="20260403-01-create-users" author="myrmec">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="users"/>
            </not>
        </preConditions>

        <createTable tableName="users">
            <column name="id" type="uuid">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="password_hash" type="varchar(100)">
                <constraints nullable="true"/>
            </column>
            <column name="provider_code" type="varchar(50)" defaultValue="LOCAL">
                <constraints nullable="false"/>
            </column>
            <column name="is_active" type="boolean" defaultValueBoolean="true">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="users"
            baseColumnNames="provider_code"
            constraintName="fk_users_auth_provider"
            referencedTableName="authentication_providers"
            referencedColumnNames="code"/>

        <sql>
            ALTER TABLE users
            ADD CONSTRAINT ck_users_provider_code
            CHECK (provider_code IS NOT NULL);
        </sql>

        <createIndex indexName="idx_users_email" tableName="users">
            <column name="email"/>
        </createIndex>

        <createIndex indexName="idx_users_provider_code" tableName="users">
            <column name="provider_code"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
