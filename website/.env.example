# Public keys/endpoints used by website forms
# These variables are safe to expose in the static frontend bundle.

# Cloudflare Turnstile site key (required for Contact + Feedback forms)
PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# Form submission endpoints (external service that sends submissions to email inbox)
PUBLIC_CONTACT_FORM_ENDPOINT=https://your-form-service.example/contact
PUBLIC_FEEDBACK_FORM_ENDPOINT=https://your-form-service.example/feedback
