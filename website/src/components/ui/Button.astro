---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  label: string;
}

const { href, variant = "primary", label } = Astro.props;
---

<a
  href={href}
  class:list={[
    "inline-flex items-center justify-center rounded-xl px-5 py-3 text-sm font-semibold transition-all duration-300",
    variant === "primary"
      ? "bg-pine text-paper hover:-translate-y-0.5 hover:bg-ink"
      : "border border-pine/35 bg-white text-pine hover:-translate-y-0.5 hover:border-pine hover:bg-paper"
  ]}
>
  {label}
</a>
