---
interface Props {
  title: string;
  body: string;
  eyebrow?: string;
}

const { title, body, eyebrow } = Astro.props;
---

<article class="soft-panel h-full p-6">
  {eyebrow && <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-clay">{eyebrow}</p>}
  <h3 class="mb-3 font-display text-xl font-bold text-ink">{title}</h3>
  <p class="text-sm leading-relaxed text-pine/85">{body}</p>
</article>
