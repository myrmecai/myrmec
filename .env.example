# Myrmec environment variables
#
# Copy this file to `.env` (or set these vars in your shell / IDE / CI) and
# fill in real values. Never commit `.env`.
#
# The values below are consumed by:
#   - control/engine          (Spring Boot reads them at startup; see application.yml)
#   - control/engine tests    (IntegrationTestBase reads GITHUB_MODELS_API_KEY)
#   - scripts/*.ps1           (E2E setup loads scripts/.env automatically)

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Override only if you are not using the docker-compose Postgres on localhost.
DATABASE_URL=jdbc:postgresql://localhost:5432/myrmec
DATABASE_USERNAME=myrmec
DATABASE_PASSWORD=secret

# ---------------------------------------------------------------------------
# Engine bootstrap admin (created on first start if both are set)
# ---------------------------------------------------------------------------
MYRMEC_ADMIN_EMAIL=
MYRMEC_ADMIN_PASSWORD=
MYRMEC_ADMIN_NAME=System Administrator

# ---------------------------------------------------------------------------
# Crypto — MUST be set in any non-dev deployment
# ---------------------------------------------------------------------------
# 32-byte secret used to encrypt stored model API keys and other credentials.
MYRMEC_ENCRYPTION_KEY=
# Comma-separated list of previous keys (kept for decryption after rotation).
MYRMEC_ENCRYPTION_PREVIOUS_KEYS=

# 256-bit random string used to sign JWT access/refresh tokens.
JWT_SECRET=
JWT_ACCESS_TOKEN_MINUTES=15
JWT_REFRESH_TOKEN_DAYS=7

# ---------------------------------------------------------------------------
# Integration / E2E tests
# ---------------------------------------------------------------------------
# GitHub Personal Access Token with `models:read` scope, used by the E2E test
# suite to call the GitHub Models inference API. If unset, tests that need
# real model calls will skip the API-key seeding step and fail loudly when
# they attempt an inference call.
GITHUB_MODELS_API_KEY=
